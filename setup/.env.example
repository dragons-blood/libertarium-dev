# ─── PLINY COMMAND — environment template ────────────────────────────────────
# Copy this file to .env (in the repo root) and fill in whichever provider
# keys you want to use. The server reads keys via os.environ — the .env file
# itself is NOT auto-sourced. Use one of:
#
#   set -a; source .env; set +a; python3 server.py
#   make run         # Makefile auto-sources .env if present
#   ./quickstart.sh  # quickstart auto-sources .env if present
#
# All keys are optional. The gauntlet only attempts targets whose key is set.
# Hermes-4-405B is used as both the JUDGE and the FALLBACK ATTACKER, so
# OPENROUTER_API_KEY is the most important one — without it the gauntlet has
# no judge and no escape hatch when Claude attackers get filtered.

# ─── REQUIRED for the judge + Hermes attacker fallback ──────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Per-provider native keys (each one optional) ───────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
XAI_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
DASHSCOPE_API_KEY=sk-...   # Qwen (Alibaba DashScope)

# ─── Optional: claude CLI for the anthropic provider in rt_send.py ──────────
# If you want to target Claude models via the local `claude` CLI sandbox
# (rather than the Anthropic native API), install Claude Code first:
#   https://docs.claude.com/en/docs/claude-code

# ─── Workspace paths (optional, sane defaults) ──────────────────────────────
# PLINY_HOME      where the installed repo lives (server.py + HTML).
#                 Defaults to the repo dir; only override for symlink installs.
# PLINY_WORKSHOP  where agents write artifacts, memory, the village repo,
#                 dragonfire, shipping logs. Defaults to ~/pliny-workshop.
#                 Point this at an existing workshop if you already have one.
# PLINY_HOME=/path/to/pliny-command
# PLINY_WORKSHOP=/path/to/pliny-workshop

# ─── Optional: dashboard auth ───────────────────────────────────────────────
# Set this to require a Bearer token on /api/* mutating endpoints. Recommended
# if you're binding to a non-loopback interface or running behind a tunnel.
# PLINY_AUTH_TOKEN=

# ─── Optional: bind address (defaults to 127.0.0.1) ────────────────────────
# PLINY_BIND_HOST=127.0.0.1
